# Supabase project the admin dashboard reads/writes against.
# Dev: Fairways-iOS-Dev (matches CLAUDE.md §3.8).
# Prod: fairways-ios-prod (provisioned at Phase 11; staging gets prod URL when it lands).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Origin used to build magic-link redirect URLs. http://localhost:3000 in dev,
# the deployed origin (e.g. https://admin.fairways.app) in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
